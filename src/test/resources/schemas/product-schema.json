{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductSchema",
  "type": "object",
  "properties": {
    "id": { "type": "integer" },
    "title": { "type": "string" },
    "price": { "type": "number" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "image": { "type": "string" },
    "rating": {
      "type": "object",
      "properties": {
        "rate": { "type": "number" },
        "count": { "type": "integer" }
      }
    }
  },
  "required": ["title", "price", "description"]
}
